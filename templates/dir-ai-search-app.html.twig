<div id="root">
<div id="unnanu-ai-search-wrapper" class="unnanu-ai-search-wrapper mt-8 px-4 pb-4 md:px-8 lg:px-12 max-w-[1500px] mx-auto w-full" data-search-type="{{ search_type }}">
   <!-- Filters Pill row will be injected here -->
   <div id="ai-search-filters-container"></div>

   <!-- AI Search Grid Layout -->
   <div class="grid grid-cols-1 gap-6 xl:grid-cols-[minmax(0,1.8fr)_minmax(360px,0.95fr)] font-sans">
       <!-- Results Column -->
       <div class="min-w-0">
           <div id="ai-search-results-container" class="bg-transparent">
               <!-- Counts / Metadata -->
               <div id="ai-search-metadata" class="mb-4 text-sm text-gray-600 hidden"></div>
               
               <!-- Loading Spinner -->
               <div class="flex items-center justify-center p-12" id="ai-search-loading">
                   <div class="animate-spin rounded-full h-12 w-12 border-b-2 border-t-2 border-[#1F40AF]"></div>
               </div>

               <!-- Results List -->
               <div id="ai-search-results-list" class="space-y-4">
                  <!-- Results dynamically populated -->
               </div>
               
               <!-- Error Message -->
               <div id="ai-search-error" class="hidden p-4 mb-4 text-sm text-red-800 rounded-lg bg-red-50"></div>
           </div>
       </div>

       <!-- Chat Column -->
       <aside class="min-w-0">
          <div class="xl:sticky xl:top-[72px]" id="ai-right-column">
              <div class="flex flex-col gap-4" id="ai-chat-faq-wrapper">
                  <!-- FAQ Panel (Injected via JS if available) -->
                  <div id="ai-faq-container" class="hidden overflow-hidden rounded-xl border border-gray-200 bg-white flex-col shadow-sm">
                      <button type="button" class="flex items-center justify-between border-b border-gray-200 px-5 py-4 text-left hover:bg-gray-50 bg-white cursor-pointer w-full" id="faq-toggle">
                          <h3 class="text-lg font-semibold leading-none text-[#1F40AF] m-0">Frequently Asked Questions</h3>
                          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-gray-500 transition-transform -rotate-90" id="faq-chevron" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
                      </button>
                      <div id="faq-list" class="min-h-0 overflow-y-auto hidden max-h-[400px] bg-white">
                      </div>
                  </div>

                  <!-- Chat Box -->
                  <div class="overflow-hidden rounded-xl border border-gray-200 bg-white flex flex-col h-[calc(100vh-140px)] min-h-[500px] shadow-sm">
                      <div class="bg-[#1F40AF] px-5 py-4 text-white flex items-center justify-between">
                          <h3 class="text-lg font-semibold flex items-center gap-2 m-0">
                              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M18 10c0 3.866-3.582 7-8 7a8.841 8.841 0 01-4.083-.98L2 17l1.338-3.123C2.493 12.767 2 11.434 2 10c0-3.866 3.582-7 8-7s8 3.134 8 7zM7 9H5v2h2V9zm8 0h-2v2h2V9zM9 9h2v2H9V9z" clip-rule="evenodd" /></svg>
                              AI Assistant
                          </h3>
                          <div class="flex items-center space-x-2">
                              <button type="button" id="ai-chat-download" class="p-1 hover:bg-white/20 rounded transition-colors text-white border-0 bg-transparent cursor-pointer" title="Download Chat">
                                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" /></svg>
                              </button>
                          </div>
                      </div>
                      
                      <div class="flex-1 overflow-y-auto p-4 space-y-4 bg-gray-50/50" id="ai-chat-messages">
                          <!-- Messages go here -->
                          <div class="flex justify-start">
                              <div class="bg-gray-100 rounded-2xl rounded-tl-sm px-4 py-2.5 max-w-[85%] text-gray-800 shadow-sm border border-gray-200 text-sm">
                                  Hello! I'm your AI Assistant. You can ask me questions about your search results.
                              </div>
                          </div>
                      </div>

                      <!-- Typing Indicator -->
                      <div id="ai-chat-typing" class="hidden px-4 pb-2 text-sm text-gray-500 italic flex items-center gap-2">
                          AI is thinking <span class="flex space-x-1"><span class="animate-bounce inline-block w-1.5 h-1.5 bg-gray-400 rounded-full"></span><span class="animate-bounce inline-block w-1.5 h-1.5 bg-gray-400 rounded-full" style="animation-delay: 0.2s"></span><span class="animate-bounce inline-block w-1.5 h-1.5 bg-gray-400 rounded-full" style="animation-delay: 0.4s"></span></span>
                      </div>

                      <div class="p-3 border-t border-gray-200 bg-white">
                          <form id="ai-chat-form" class="relative m-0">
                              <textarea id="ai-chat-input" rows="1" class="w-full resize-none rounded-lg border border-gray-300 py-3 pl-4 pr-12 focus:border-[#1F40AF] focus:outline-none focus:ring-1 focus:ring-[#1F40AF] shadow-sm text-sm text-gray-900 placeholder-gray-400 m-0 box-border" placeholder="Ask for more details..."></textarea>
                              <button type="submit" class="absolute right-2 top-1/2 -translate-y-1/2 rounded-full p-2 text-gray-400 hover:text-[#1F40AF] transition-colors disabled:opacity-50 border-0 bg-transparent cursor-pointer" id="ai-chat-submit">
                                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-6 w-6"><path d="M3.478 2.405a.75.75 0 00-.926.94l2.432 7.905H13.5a.75.75 0 010 1.5H4.984l-2.432 7.905a.75.75 0 00.926.94 60.519 60.519 0 0018.445-8.986.75.75 0 000-1.218A60.517 60.517 0 003.478 2.405z" /></svg>
                              </button>
                          </form>
                      </div>
                  </div>
              </div>
              <div id="ai-preview-panel-wrapper" class="hidden overflow-hidden rounded-xl border border-gray-200 bg-white flex-col shadow-sm"></div>
          </div>
       </aside>
   </div>
</div></div>
